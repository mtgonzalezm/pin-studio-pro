{
  "name": "pin-studio-pro",
  "version": "1.0.0",
  "description": "Editor de imágenes interactivas con chinchetas personalizables para educación",
  "author": "Teresa González",
  "homepage": "https://github.com/mtgonzalezm/pin-studio-pro",
  "main": "public/main.js",
  "private": true,
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-scripts": "5.0.1",
    "lucide-react": "0.263.1",
    "electron-is-dev": "2.0.0"
  },
  "devDependencies": {
    "electron": "31.0.0",
    "electron-builder": "25.0.0",
    "concurrently": "8.0.0",
    "wait-on": "7.0.0"
  },
  "scripts": {
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "react-test": "react-scripts test",
    "react-eject": "react-scripts eject",
    "electron-start": "wait-on http://localhost:3000 && electron .",
    "start": "concurrently \"npm run react-start\" \"npm run electron-start\"",
    "build": "npm run react-build && electron-builder",
    "build-win": "npm run react-build && electron-builder --win",
    "build-mac": "npm run react-build && electron-builder --mac",
    "build-all": "npm run react-build && electron-builder -mw"
  },
  "build": {
    "appId": "com.pinstadiupro.app",
    "productName": "PIN STUDIO PRO",
    "files": [
      "build/**/*",
      "public/main.js",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "assets/icon.icns",
      "category": "public.app-category.education"
    },
    "dmg": {
      "sign": false
    }
  },
  "browserslist": {
    "production": [">0.2%", "not dead", "not op_mini all"],
    "development": ["last 1 chrome version", "last 1 firefox version", "last 1 safari version"]
  }
}
